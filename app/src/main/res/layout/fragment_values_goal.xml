<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="vm"
            type="com.tech.young.ui.investment_tracker.InvestmentTrackingVm" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.investment_tracker.ValuesGoalFragment">


        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvAddInvestment"
                    style="@style/TextView_700_Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_investment"
                    android:textSize="@dimen/_14ssp"
                    android:textColor="@color/colorPrimary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>



                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvDes"
                    style="@style/TextView_400_Regular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/_11ssp"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:textColor="@color/text_gray"
                    android:text="Add assets to get smarter portfolio insights"
                    app:layout_constraintTop_toBottomOf="@id/tvAddInvestment"
                    app:layout_constraintStart_toStartOf="parent"/>


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvSymbol"
                    style="@style/TextView_500_Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ticker_symbol"
                    android:textSize="@dimen/_13ssp"
                    android:layout_marginTop="@dimen/_13sdp"
                    android:textColor="@color/colorPrimary"
                    app:layout_constraintTop_toBottomOf="@id/tvDes"
                    app:layout_constraintStart_toStartOf="parent" />


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvType"
                    style="@style/TextView_500_Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Type"
                    android:textSize="@dimen/_13ssp"
                    android:layout_marginTop="@dimen/_13sdp"
                    android:textColor="@color/colorPrimary"
                    app:layout_constraintTop_toBottomOf="@id/tvDes"
                    app:layout_constraintStart_toStartOf="@id/etType" />


                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/etSymbol"
                    style="@style/TextView_400_Regular"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_42sdp"
                    android:layout_marginTop="@dimen/_3sdp"
                    android:background="@drawable/radius_border_gray"
                    android:layout_marginEnd="@dimen/_12sdp"
                    android:imeOptions="actionNext"
                    android:inputType="textCapSentences"
                    android:nextFocusForward="@id/etType"
                    android:gravity="start|center"
                    android:hint="e.g. AAPL"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:singleLine="true"
                    android:textColorHint="@color/text_gray"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/etType"
                    app:layout_constraintTop_toBottomOf="@+id/tvSymbol" />
                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/etType"
                    style="@style/TextView_400_Regular"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_42sdp"
                    android:imeOptions="actionDone"
                    android:background="@drawable/radius_border_gray"
                    android:gravity="start|center"
                    android:hint="Stoke"
                    android:focusable="false"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:singleLine="true"
                    android:inputType="textCapSentences"
                    android:textColorHint="@color/text_gray"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/etSymbol"
                    app:layout_constraintTop_toTopOf="@+id/etSymbol" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:src="@drawable/iv_dropdown"
                    app:layout_constraintBottom_toBottomOf="@+id/etType"
                    app:layout_constraintEnd_toEndOf="@+id/etType"
                    app:layout_constraintTop_toTopOf="@+id/etType" />


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvCurrentValue"
                    style="@style/TextView_500_Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/current_value"
                    android:textSize="@dimen/_13ssp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:textColor="@color/colorPrimary"
                    app:layout_constraintTop_toBottomOf="@id/etSymbol"
                    app:layout_constraintStart_toStartOf="parent" />


                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/etCurrentValue"
                    style="@style/TextView_400_Regular"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_42sdp"
                    android:layout_marginTop="@dimen/_3sdp"
                    android:background="@drawable/radius_border_gray"
                    android:layout_marginEnd="@dimen/_12sdp"
                    android:imeOptions="actionNext"
                    android:inputType="textCapSentences"
                    android:nextFocusForward="@id/etType"
                    android:gravity="start|center"
                    android:hint="e.g. 5000"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:singleLine="true"
                    android:textColorHint="@color/text_gray"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/etShare"
                    app:layout_constraintTop_toBottomOf="@+id/tvCurrentValue" />



                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvShare"
                    style="@style/TextView_500_Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="# of Shares / Units"
                    android:textSize="@dimen/_13ssp"
                    android:textColor="@color/colorPrimary"
                    app:layout_constraintTop_toTopOf="@id/tvCurrentValue"
                    app:layout_constraintStart_toStartOf="@id/etShare" />
                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/etShare"
                    style="@style/TextView_400_Regular"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_42sdp"
                    android:imeOptions="actionDone"
                    android:background="@drawable/radius_border_gray"
                    android:gravity="start|center"
                    android:hint="e.g. 25.5"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:singleLine="true"
                    android:inputType="textCapSentences"
                    android:textColorHint="@color/text_gray"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/etCurrentValue"
                    app:layout_constraintTop_toTopOf="@+id/etCurrentValue" />


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvInvestment"
                    style="@style/TextView_500_Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Is this investment performing well?"
                    android:textSize="@dimen/_13ssp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:textColor="@color/colorPrimary"
                    app:layout_constraintTop_toBottomOf="@id/etCurrentValue"
                    app:layout_constraintStart_toStartOf="parent" />


                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/etInvestment"
                    style="@style/TextView_400_Regular"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_42sdp"
                    android:layout_marginTop="@dimen/_3sdp"
                    android:background="@drawable/radius_border_gray"
                    android:gravity="start|center"
                    android:hint="Yes — outperforming my expectations"
                    android:imeOptions="actionNext"
                    android:inputType="textCapSentences"
                    android:nextFocusForward="@id/etType"
                    android:paddingStart="@dimen/_10sdp"
                    android:paddingEnd="@dimen/_40sdp"
                    android:singleLine="true"
                    android:focusable="false"
                    android:textColorHint="@color/text_gray"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvInvestment" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:src="@drawable/iv_dropdown"
                    app:layout_constraintBottom_toBottomOf="@+id/etInvestment"
                    app:layout_constraintEnd_toEndOf="@+id/etInvestment"
                    app:layout_constraintTop_toTopOf="@+id/etInvestment" />


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvGeneralInvestment"
                    style="@style/TextView_500_Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="General investments"
                    android:textSize="@dimen/_13ssp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:textColor="@color/colorPrimary"
                    app:layout_constraintTop_toBottomOf="@id/etInvestment"
                    app:layout_constraintStart_toStartOf="parent" />



                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/etSaving"
                    style="@style/TextView_400_Regular"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_42sdp"
                    android:layout_marginTop="@dimen/_3sdp"
                    android:background="@drawable/radius_border_gray"
                    android:imeOptions="actionNext"
                    android:inputType="textCapSentences"
                    android:nextFocusForward="@id/etType"
                    android:gravity="start|center"
                    android:focusable="false"
                    android:hint="Savings Wells Fargo $12,000"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:singleLine="true"
                    android:textColorHint="@color/text_gray"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvGeneralInvestment" />



                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:src="@drawable/iv_dropdown"
                    app:layout_constraintBottom_toBottomOf="@+id/etSaving"
                    app:layout_constraintEnd_toEndOf="@+id/etSaving"
                    app:layout_constraintTop_toTopOf="@+id/etSaving" />


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvAddToPortfolio"
                    style="@style/TextView_500_Medium"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_42sdp"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:background="@drawable/corner_radius_10"
                    android:gravity="center"
                    android:onClick="@{v ->vm.onClick(v)}"
                    android:text="@string/add_to_portfolio"
                    android:textColor="@color/white"
                    android:visibility="visible"
                    app:layout_constraintTop_toBottomOf="@id/etSaving"/>


            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>