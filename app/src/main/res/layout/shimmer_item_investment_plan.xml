<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_popup"
    android:backgroundTint="@color/light_gray"
    android:layout_marginBottom="@dimen/_10sdp"
    android:padding="@dimen/_10sdp">

    <View
        android:id="@+id/vTitle"
        android:layout_width="@dimen/_100sdp"
        android:layout_height="@dimen/_15sdp"
        android:background="#DDDDDD"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/vPlanName"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_10sdp"
        android:background="#DDDDDD"
        android:layout_marginTop="@dimen/_8sdp"
        app:layout_constraintTop_toBottomOf="@id/vTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/vCategoryTitle"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="@dimen/_15sdp"
        android:background="#DDDDDD"
        android:layout_marginTop="@dimen/_12sdp"
        app:layout_constraintTop_toBottomOf="@id/vPlanName"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/vCategory"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_10sdp"
        android:background="#DDDDDD"
        android:layout_marginTop="@dimen/_8sdp"
        app:layout_constraintTop_toBottomOf="@id/vCategoryTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/vAllocationTitle"
        android:layout_width="@dimen/_90sdp"
        android:layout_height="@dimen/_15sdp"
        android:background="#DDDDDD"
        android:layout_marginTop="@dimen/_12sdp"
        app:layout_constraintTop_toBottomOf="@id/vCategory"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/vAllocation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_10sdp"
        android:background="#DDDDDD"
        android:layout_marginTop="@dimen/_8sdp"
        app:layout_constraintTop_toBottomOf="@id/vAllocationTitle"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>