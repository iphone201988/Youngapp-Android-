<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="vm"
            type="com.tech.young.ui.my_profile_screens.YourProfileVM" />

        <variable
            name="bean"
            type="com.tech.young.data.model.Performance" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.my_profile_screens.forNormal.PerformanceFragment">



    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginHorizontal="@dimen/_18sdp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/_10sdp">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivBack"
            android:layout_width="@dimen/_35sdp"
            android:layout_height="@dimen/_35sdp"
            android:background="@drawable/rounded_bg"
            android:onClick="@{v ->vm.onClick(v)}"
            android:padding="@dimen/_8sdp"
            android:src="@drawable/iv_back_symbol"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:id="@+id/tvHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextView_600_SemiBold"
            android:text="@string/investment_summary"
            android:layout_marginStart="@dimen/_10sdp"
            app:layout_constraintTop_toTopOf="@id/ivBack"
            app:layout_constraintBottom_toBottomOf="@id/ivBack"
            app:layout_constraintStart_toEndOf="@id/ivBack"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/actionToggleBtn"
            android:layout_width="@dimen/_35sdp"
            android:layout_height="@dimen/_35sdp"
            android:onClick="@{v -> vm.onClick(v)}"
            android:src="@drawable/iv_drawer"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmerLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/clTopBar"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible">
        <include layout="@layout/shimmer_performance"/>
    </com.facebook.shimmer.ShimmerFrameLayout>


    <androidx.core.widget.NestedScrollView
        android:id="@+id/clInvestment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fitsSystemWindows="true"
        android:fillViewport="true"
        android:layout_marginTop="@dimen/_20sdp"
        android:layout_marginBottom="@dimen/_18sdp"
        app:layout_constraintStart_toStartOf="@id/clTopBar"
        app:layout_constraintEnd_toEndOf="@id/clTopBar"
        app:layout_constraintTop_toBottomOf="@id/clTopBar"
        app:layout_constraintBottom_toBottomOf="parent">
        
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        
        
        
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/consQuarterly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5sdp"
            android:background="@color/bg_selected_sideMenu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">


            <ImageView
                android:id="@+id/ivInfo"
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:src="@drawable/ic_info"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/gray" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvInfo"
                style="@style/TextView_400_Regular"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_5sdp"
                android:textColor="@color/gray"
                android:textSize="@dimen/_12ssp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivInfo"
                app:layout_constraintTop_toTopOf="@id/ivInfo" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvPolicyVariance"
            style="@style/TextView_700_Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile Variance Summary"
            android:textColor="@color/colorPrimary"
            android:textSize="@dimen/_14ssp"
            android:layout_marginTop="@dimen/_18sdp"
            app:layout_constraintTop_toBottomOf="@id/consQuarterly"
            app:layout_constraintStart_toStartOf="parent"/>
        
        
        
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/consRiskLevel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingVertical="@dimen/_16sdp"
            android:layout_marginTop="@dimen/_13sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            app:layout_constraintEnd_toStartOf="@id/consIncome"
            android:background="@drawable/bg_cons_performance"
            app:layout_constraintTop_toBottomOf="@id/tvPolicyVariance"
            app:layout_constraintStart_toStartOf="parent">


            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivLevelArrow"
                setArrowDirection="@{bean.riskLevel}"
                android:layout_width="@dimen/_18sdp"
                android:layout_height="@dimen/_18sdp"
                android:src="@drawable/iv_arrow"
                app:tint="@color/green"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>



            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextView_700_Bold"
                android:text='@{bean.riskLevel + " Level"}'
                android:textSize="@dimen/_14ssp"
                android:textColor="@color/green"
                app:layout_constraintTop_toBottomOf="@id/ivLevelArrow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextView_400_Regular"
                android:text="Risk Level "
                android:layout_marginTop="@dimen/_5sdp"
                android:textSize="@dimen/_11ssp"
                android:textColor="@color/text_gray"
                app:layout_constraintTop_toBottomOf="@id/tvLevel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/consIncome"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingVertical="@dimen/_16sdp"
            android:background="@drawable/bg_cons_performance"
            app:layout_constraintTop_toTopOf="@id/consRiskLevel"
            app:layout_constraintStart_toEndOf="@id/consRiskLevel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/consRiskLevel">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivIncomeArrow"
                android:layout_width="@dimen/_18sdp"
                android:layout_height="@dimen/_18sdp"
                setArrowDirection="@{bean.income}"

                android:src="@drawable/iv_arrow"
                app:tint="@color/green"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>



            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvIncome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextView_700_Bold"
                android:text='@{bean.income + " /yr"}'
                android:textSize="@dimen/_14ssp"
                android:textColor="@color/green"
                app:layout_constraintTop_toBottomOf="@id/ivIncomeArrow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextView_400_Regular"
                android:text="Income"
                android:layout_marginTop="@dimen/_5sdp"
                android:textSize="@dimen/_11ssp"
                android:textColor="@color/text_gray"
                app:layout_constraintTop_toBottomOf="@id/tvIncome"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>



        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/consSaving"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingVertical="@dimen/_16sdp"
            android:layout_marginTop="@dimen/_13sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            app:layout_constraintEnd_toStartOf="@id/consInterests"
            android:background="@drawable/bg_cons_performance"
            app:layout_constraintTop_toBottomOf="@id/consRiskLevel"
            app:layout_constraintStart_toStartOf="parent">


            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivSavingArrow"
                android:layout_width="@dimen/_18sdp"
                android:layout_height="@dimen/_18sdp"
                android:src="@drawable/iv_arrow"
                app:tint="@color/green"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>



            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvSaving"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextView_700_Bold"
                android:text="-"
                android:textSize="@dimen/_14ssp"
                android:textColor="@color/green"
                app:layout_constraintTop_toBottomOf="@id/ivSavingArrow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextView_400_Regular"
                android:text="Savings"
                android:layout_marginTop="@dimen/_5sdp"
                android:textSize="@dimen/_11ssp"
                android:textColor="@color/text_gray"
                app:layout_constraintTop_toBottomOf="@id/tvSaving"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/consInterests"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingVertical="@dimen/_16sdp"
            android:background="@drawable/bg_cons_performance"
            app:layout_constraintTop_toTopOf="@id/consSaving"
            app:layout_constraintStart_toEndOf="@id/consSaving"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/consSaving">


            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivTopicArrow"
                android:layout_width="@dimen/_18sdp"
                android:layout_height="@dimen/_18sdp"
                setArrowDirection="@{bean.topics}"
                android:src="@drawable/iv_arrow"
                app:tint="@color/green"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>



            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTopics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextView_700_Bold"
                android:text='@{bean.topics + " Topics"}'
                android:textSize="@dimen/_14ssp"
                android:textColor="@color/green"
                app:layout_constraintTop_toBottomOf="@id/ivTopicArrow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextView_400_Regular"
                android:text="Interests"
                android:layout_marginTop="@dimen/_5sdp"
                android:textSize="@dimen/_11ssp"
                android:textColor="@color/text_gray"
                app:layout_constraintTop_toBottomOf="@id/tvTopics"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>



        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="0dp"
            android:layout_height="@dimen/_45sdp"
            android:layout_marginTop="@dimen/_20sdp"
            android:background="@drawable/tab_bg"
            app:tabGravity="fill"
            app:tabMode="fixed"
            app:tabMinWidth="0dp"
            app:tabTextAppearance="@style/TabTextStyle"
            app:tabIndicator="@drawable/tab_indicator"
            app:tabIndicatorFullWidth="false"
            app:tabTextColor="@color/white"
            app:tabSelectedTextColor="@color/white"
            app:tabIndicatorColor="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/consInterests" />



        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/_10sdp"
            app:layout_constraintTop_toBottomOf="@id/tabLayout"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>