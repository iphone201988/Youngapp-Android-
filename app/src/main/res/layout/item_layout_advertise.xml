<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="bean"
            type="com.tech.young.data.model.Ad" />
        <variable
            name="callback"
            type="com.tech.young.base.SimpleRecyclerViewAdapter.SimpleCallback" />
        <variable
            name="pos"
            type="Integer" />


        <import type="android.view.View"/>
        <import type="android.text.TextUtils"/>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/_10sdp"
        android:layout_marginBottom="@dimen/_10sdp"
        android:background="@drawable/profile_share_bg">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivImage"
            android:visibility='@{TextUtils.isEmpty(bean.file) ? View.GONE : View.VISIBLE}'
            setImageFromUrl="@{bean.file}"
            android:layout_width="0dp"
            android:layout_height="@dimen/_150sdp"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="@dimen/_8sdp"
            android:scaleType="centerCrop"
            android:src="@drawable/dummy_profile"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="@style/Shape10" />



        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextView_600_SemiBold"
            android:text="Plan Name"
            android:layout_marginTop="@dimen/_20sdp"
            android:textSize="@dimen/_14ssp"
            android:layout_marginStart="@dimen/_8sdp"
            android:textColor="@color/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/ivImage"
            app:layout_constraintStart_toStartOf="parent" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/etName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_12ssp"
            android:text="@{bean.name}"
            android:textColor="@color/gray"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/_5sdp"
            app:layout_constraintTop_toBottomOf="@id/tvName"
            app:layout_constraintStart_toStartOf="@id/tvName"/>



        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvCompany"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextView_600_SemiBold"
            android:text="Company"
            android:layout_marginTop="@dimen/_5sdp"
            android:textSize="@dimen/_14ssp"
            android:textColor="@color/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/etName"
            app:layout_constraintStart_toStartOf="@id/tvName" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/etCompany"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_12ssp"
            android:text="@{bean.company}"
            android:textColor="@color/gray"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/_5sdp"
            app:layout_constraintTop_toBottomOf="@id/tvCompany"
            app:layout_constraintStart_toStartOf="@id/tvCompany"/>



        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextView_600_SemiBold"
            android:text="Email"
            android:layout_marginTop="@dimen/_5sdp"
            android:textSize="@dimen/_14ssp"
            android:textColor="@color/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/etCompany"
            app:layout_constraintStart_toStartOf="@id/tvName" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/etEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_12ssp"
            android:textColor="@color/gray"
            android:text="@{bean.email}"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/_5sdp"
            app:layout_constraintTop_toBottomOf="@id/tvEmail"
            app:layout_constraintStart_toStartOf="@id/tvEmail"/>



        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvWebsite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextView_600_SemiBold"
            android:text="Website"
            android:layout_marginTop="@dimen/_5sdp"
            android:textSize="@dimen/_14ssp"
            android:textColor="@color/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/etEmail"
            app:layout_constraintStart_toStartOf="@id/tvName" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/etWebsite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_12ssp"
            android:text="@{bean.website}"
            android:textColor="@color/gray"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/_5sdp"
            app:layout_constraintTop_toBottomOf="@id/tvWebsite"
            app:layout_constraintStart_toStartOf="@id/tvWebsite"/>


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvPlan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextView_600_SemiBold"
            android:text="Plan"
            android:layout_marginTop="@dimen/_5sdp"
            android:textSize="@dimen/_14ssp"
            android:textColor="@color/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/etWebsite"
            app:layout_constraintStart_toStartOf="@id/tvName" />



        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/etPlan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_12ssp"
            app:adsPlan="@{bean.adsPlan}"
            android:textColor="@color/gray"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/_5sdp"
            app:layout_constraintTop_toBottomOf="@id/tvPlan"
            app:layout_constraintStart_toStartOf="@id/tvWebsite"/>



        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSubmit"
            style="@style/TextView_500_Medium"
            android:layout_width="match_parent"
            app:documentStatus="@{bean.status}"
            android:layout_height="@dimen/_42sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginHorizontal="@dimen/_8sdp"
            android:background="@drawable/corner_radius_10"
            android:gravity="center"
            android:text="@string/submit"
            android:textColor="@color/white"
            android:visibility="visible"
            app:layout_constraintTop_toBottomOf="@id/etPlan"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>